# Frontend environment variables for local Next.js development and Vercel.
#
# Choose one mode:
# 1. Recommended proxy mode:
#    - leave NEXT_PUBLIC_API_URL unset
#    - set BACKEND_PROXY_URL
# 2. Direct browser-to-backend mode:
#    - set NEXT_PUBLIC_API_URL
#    - leave BACKEND_PROXY_URL unset

# Recommended on Vercel
BACKEND_PROXY_URL=https://your-backend.example.com

# Optional direct-call mode
# NEXT_PUBLIC_API_URL=https://your-backend.example.com

# Optional local development example
# NEXT_PUBLIC_API_URL=http://localhost:8010
