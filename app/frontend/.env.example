# One-project mode: leave NEXT_PUBLIC_API_URL unset so the app uses same-origin
# Next.js route handlers under /api/*.
# NEXT_PUBLIC_API_URL=

# Server-side LLM configuration for Next.js route handlers
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
# OPENAI_BASE_URL=https://api.openai.com/v1
# CALCSENSE_MODEL=gpt-4.1

# Optional legacy split-backend mode
# BACKEND_PROXY_URL=https://your-backend.example.com
# NEXT_PUBLIC_API_URL=https://your-backend.example.com
