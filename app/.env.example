EFT_RUNTIME=local
EFT_API_ENV=test

# LLM mode
EFT_LLM_MODE=mock

# OpenAI-compatible configuration
# For direct OpenAI-compatible usage, prefer OPENAI_API_KEY and optionally OPENAI_BASE_URL.
# For older proxy-based setups, the *_apikey and LLM_PROXY_* settings still work.
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
# OPENAI_BASE_URL=https://api.openai.com/v1

# Legacy proxy-compatible settings
test_apikey=YOUR_API_KEY_HERE
corp_apikey=YOUR_API_KEY_HERE
LLM_PROXY_HOST=your-proxy-host.example.com
LLM_PROXY_SCHEME=https
# EFT_OPENAI_PROXY_URL=https://your-proxy-host.example.com/v1/proxy/azure-openai
# EFT_BEDROCK_PROXY_URL=https://your-proxy-host.example.com/v1/proxy/bedrock
# EFT_PROXY_AUTH_TOKEN=Basic YOUR_PROXY_TOKEN

AWS_REGION=us-east-1
APP_NAME=calcsense
NEXT_PUBLIC_API_URL=http://localhost:8000
WHISPER_MODEL_SIZE=small
CALCSENSE_CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CALCSENSE_TRUSTED_HOSTS=localhost,127.0.0.1
CALCSENSE_LOG_LEVEL=INFO

# Optional runtime recalculation through LibreOffice
CALCSENSE_USE_LIBREOFFICE_RECALC=false
# LIBREOFFICE_BIN=/Applications/LibreOffice.app/Contents/MacOS/soffice
